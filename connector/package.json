{
  "name": "zenithmc-connector",
  "version": "0.1.0",
  "description": "ZenithMC friend-side connector — exposes localhost to Minecraft and carries it over the direct P2P link to the host.",
  "type": "module",
  "main": "electron-main.mjs",
  "bin": {
    "zenithmc-connector": "src/index.mjs"
  },
  "scripts": {
    "start": "node src/index.mjs",
    "serve": "node src/control.mjs",
    "icon": "node build/gen-icon.mjs",
    "dist": "node build/gen-icon.mjs && electron-builder",
    "check": "node --check src/index.mjs && node --check src/control.mjs && node --check src/autostart.mjs && node --check electron-main.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "node-datachannel": "^0.32.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.zenithurl.zenithmc.connector",
    "productName": "ZenithMC Connector",
    "files": ["electron-main.mjs", "src/**/*", "build/tray.png", "../shared/**/*"],
    "asarUnpack": ["**/node_modules/node-datachannel/**"],
    "win": { "target": "nsis" },
    "nsis": { "oneClick": true, "perMachine": false, "runAfterFinish": true }
  }
}
